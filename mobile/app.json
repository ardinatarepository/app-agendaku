        "backgroundColor": "#1E1E1E"
      },
      "package": "com.agendaku.app"
    },
    "plugins": [
      "expo-font"
    ],
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "d5323be0-d069-4839-8dd0-532150031c2d"
      }
    },
    "owner": "ardinata16",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d5323be0-d069-4839-8dd0-532150031c2d"
    }
  }
