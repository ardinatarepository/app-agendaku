# AgendaKu Backend - Environment Variables
# Salin file ini menjadi .env dan sesuaikan nilainya

# ─── Database ────────────────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/agendaku_db"

# ─── JWT ─────────────────────────────────────────────────────────────────
# Ganti dengan string acak yang panjang dan aman
JWT_SECRET="agendaku-super-secret-key-ganti-ini-di-production"
JWT_EXPIRES_IN="7d"

# ─── Server ───────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────
# URL frontend web yang diizinkan mengakses API
CORS_ORIGIN="http://localhost:5173"
